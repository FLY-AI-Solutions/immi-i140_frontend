                              onChange={(e) => updateExhibit(index, e.target.value)}
                              className="w-full bg-slate-50 border border-slate-200 rounded-lg p-3 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-shadow min-h-[60px] resize-y text-slate-700 font-serif"
                              placeholder="Describe the exhibit (e.g., Copies of advanced degrees and transcripts)"
                            />
                            
                            {/* Individual File Attachment Button */}
                            <div className="flex items-center gap-2">
                              <input 
                                type="file" 
                                className="hidden" 
                                id={`exhibit-attach-${index}`} 
                                onChange={(e) => handleExhibitAttachment(index, e)} 
                              />
                              <label 
                                htmlFor={`exhibit-attach-${index}`} 
                                className={`cursor-pointer text-xs font-semibold px-4 py-2 rounded-lg flex items-center gap-2 transition-colors ${exhibit.attachedFile ? 'bg-blue-50 text-blue-700 border border-blue-200' : 'bg-slate-100 text-slate-600 hover:bg-slate-200 border border-transparent'}`}
                              >
                                <Paperclip /> 
                                {exhibit.attachedFile ? exhibit.attachedFile.name : 'Attach PDF/Image File'}
                              </label>
                            </div>
                          </div>
                          
                          <button onClick={() => removeExhibit(index)} className="p-2 mt-1 text-slate-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-colors md:opacity-0 group-hover:opacity-100 focus:opacity-100">
                            <Trash2 />
                          </button>
                        </div>
                      ))}
                    </div>
                  )}

                  {exhibits.length > 0 && (
                     <button onClick={addExhibit} className="mt-6 flex items-center gap-2 text-sm font-medium text-blue-600 bg-blue-50 hover:bg-blue-100 px-4 py-2 rounded-lg transition-colors">
                       + Add Custom Exhibit Row
                     </button>
                  )}
                </div>
              </div>
              
              <div className="flex justify-end">
                <button onClick={() => setActiveStep(2)} className="flex items-center gap-2 bg-slate-900 text-white px-6 py-3 rounded-xl hover:bg-slate-800 transition-colors font-medium">
                  Next: Review Introduction <ChevronRight />
                </button>
              </div>
            </div>
          )}

          {/* STEP 2: INTRODUCTION */}
          {activeStep === 2 && (
            <div className="space-y-6 animate-in fade-in slide-in-from-bottom-4 duration-500">
              <div className="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                <div className="p-6 border-b border-slate-100 bg-slate-50/50 flex justify-between items-start">
                  <div>
                    <h2 className="text-2xl font-bold text-slate-800 flex items-center gap-3">
                      Petition Introduction
                      {isAgentPopulated && (
                        <span className="text-xs font-medium bg-indigo-100 text-indigo-700 px-2.5 py-1 rounded-full flex items-center gap-1 mt-1">
                          <Sparkles /> Auto-populated by AI
                        </span>
                      )}
                    </h2>
                    <p className="text-slate-500 mt-1 text-sm">Set the stage for the reviewing officer. State clearly what you are applying for.</p>
                  </div>
                  <button 
                    onClick={() => handleSimulateAI('Introduction')}
                    disabled={isGenerating || !intro}
                    className="flex items-center gap-2 bg-indigo-50 text-indigo-700 border border-indigo-100 px-4 py-2 rounded-lg text-sm font-medium hover:bg-indigo-100 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                  >
                    {isGenerating ? <span className="animate-pulse">Polishing...</span> : <><Sparkles /> Agent Polish</>}
                  </button>
                </div>
                
                <div className="p-6">
                  {!intro && !isAgentPopulated && (
                    <div className="bg-amber-50 text-amber-800 p-4 rounded-xl text-sm mb-6 flex gap-3 border border-amber-200">
                      <Info className="flex-shrink-0 text-amber-600" />
                      <p>This section is currently empty. Go back to <strong>Step 1</strong> to upload your `.flyai` profile and let the AI Agent draft this for you, or start typing below.</p>
                    </div>
                  )}
                  
                  <textarea 
                    value={intro}
                    onChange={(e) => setIntro(e.target.value)}
                    className="w-full bg-white border border-slate-300 rounded-xl p-6 text-base leading-relaxed focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-shadow min-h-[300px] font-serif shadow-inner"
                    placeholder="Write your introduction here..."
                  />
                </div>
              </div>
              
              <div className="flex justify-between">
                <button onClick={() => setActiveStep(1)} className="px-6 py-3 rounded-xl text-slate-600 hover:bg-slate-100 transition-colors font-medium">
                  Back
                </button>
                <button onClick={() => setActiveStep(3)} className="flex items-center gap-2 bg-slate-900 text-white px-6 py-3 rounded-xl hover:bg-slate-800 transition-colors font-medium">
                  Next: Legal Arguments <ChevronRight />
                </button>
              </div>
            </div>
          )}

          {/* STEP 3: LEGAL ARGUMENTS (DHANASAR) */}
          {activeStep === 3 && (
            <div className="space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-500">
              
              <div className="mb-4 flex items-center justify-between">
                <div>
                  <h2 className="text-3xl font-bold text-slate-800 flex items-center gap-3">
                    The Legal Arguments
                  </h2>
                  <p className="text-slate-500 mt-2">Address the specific requirements established by Matter of Dhanasar.</p>
                </div>
                {isAgentPopulated && (
                  <div className="text-sm font-medium bg-indigo-100 text-indigo-700 px-4 py-2 rounded-xl flex items-center gap-2">
                    <Sparkles /> Prongs auto-drafted by AI Agent
                  </div>
                )}
              </div>

              {/* Prong 1 */}
              <div className="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                <div className="p-5 border-b border-slate-100 bg-slate-50 flex justify-between items-center">
                  <h3 className="text-lg font-bold text-slate-800 flex items-center gap-2">
                    <span className="bg-slate-200 text-slate-700 w-6 h-6 rounded flex items-center justify-center text-xs">1</span> 
                    Advanced Degree Professional
                  </h3>
                  <button onClick={() => handleSimulateAI('Prong 1')} className="text-indigo-600 hover:text-indigo-800 text-sm font-medium flex items-center gap-1">
                    <Sparkles /> Improve
                  </button>
                </div>
                <div className="p-5">
                  <textarea 
                    value={prong1}
                    onChange={(e) => setProng1(e.target.value)}
                    className="w-full bg-white border border-slate-200 rounded-xl p-5 text-base leading-relaxed focus:ring-2 focus:ring-blue-500 font-serif min-h-[150px]"
                    placeholder="Provide evidence of advanced degree..."
                  />
                </div>
              </div>

              {/* Prong 2 */}
              <div className="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                <div className="p-5 border-b border-slate-100 bg-slate-50 flex justify-between items-center">
                  <h3 className="text-lg font-bold text-slate-800 flex items-center gap-2">
                    <span className="bg-slate-200 text-slate-700 w-6 h-6 rounded flex items-center justify-center text-xs">2</span> 
                    Substantial Merit & National Importance
                  </h3>
                  <button onClick={() => handleSimulateAI('Prong 2')} className="text-indigo-600 hover:text-indigo-800 text-sm font-medium flex items-center gap-1">
                    <Sparkles /> Improve
                  </button>
                </div>
                <div className="p-5">
                  <textarea 
                    value={prong2}
                    onChange={(e) => setProng2(e.target.value)}
                    className="w-full bg-white border border-slate-200 rounded-xl p-5 text-base leading-relaxed focus:ring-2 focus:ring-blue-500 font-serif min-h-[250px]"
                    placeholder="Argue the substantial merit and national importance..."
                  />
                </div>
              </div>

              {/* Prong 3 */}
              <div className="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                <div className="p-5 border-b border-slate-100 bg-slate-50 flex justify-between items-center">
                  <h3 className="text-lg font-bold text-slate-800 flex items-center gap-2">
                    <span className="bg-slate-200 text-slate-700 w-6 h-6 rounded flex items-center justify-center text-xs">3</span> 
                    Well Positioned to Advance the Endeavor
                  </h3>
                  <button onClick={() => handleSimulateAI('Prong 3')} className="text-indigo-600 hover:text-indigo-800 text-sm font-medium flex items-center gap-1">
                    <Sparkles /> Improve
                  </button>
                </div>
                <div className="p-5">
                  <textarea 
                    value={prong3}
                    onChange={(e) => setProng3(e.target.value)}
                    className="w-full bg-white border border-slate-200 rounded-xl p-5 text-base leading-relaxed focus:ring-2 focus:ring-blue-500 font-serif min-h-[250px]"
                    placeholder="Detail positioning to advance the endeavor..."
                  />
                </div>
              </div>

              {/* Prong 4 */}
              <div className="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                <div className="p-5 border-b border-slate-100 bg-slate-50 flex justify-between items-center">
                  <h3 className="text-lg font-bold text-slate-800 flex items-center gap-2">
                    <span className="bg-slate-200 text-slate-700 w-6 h-6 rounded flex items-center justify-center text-xs">4</span> 
                    Balancing Test (Waiving Job Offer)
                  </h3>
                  <button onClick={() => handleSimulateAI('Prong 4')} className="text-indigo-600 hover:text-indigo-800 text-sm font-medium flex items-center gap-1">
                    <Sparkles /> Improve
                  </button>
                </div>
                <div className="p-5">
                  <textarea 
                    value={prong4}
                    onChange={(e) => setProng4(e.target.value)}
                    className="w-full bg-white border border-slate-200 rounded-xl p-5 text-base leading-relaxed focus:ring-2 focus:ring-blue-500 font-serif min-h-[200px]"
                    placeholder="Argue why waiving the job offer benefits the US..."
                  />
                </div>
              </div>
              
              <div className="flex justify-between pb-8">
                <button onClick={() => setActiveStep(2)} className="px-6 py-3 rounded-xl text-slate-600 hover:bg-slate-100 transition-colors font-medium">
                  Back
                </button>
                <button onClick={() => setActiveStep(4)} className="flex items-center gap-2 bg-slate-900 text-white px-6 py-3 rounded-xl hover:bg-slate-800 transition-colors font-medium">
                  Next: Final Review <ChevronRight />
                </button>
              </div>
            </div>
          )}

          {/* STEP 4: FINAL REVIEW */}
          {activeStep === 4 && (
            <div className="space-y-6 animate-in fade-in slide-in-from-bottom-4 duration-500">
              <div className="bg-white rounded-2xl border border-slate-200 shadow-sm p-8 max-w-4xl mx-auto">
                
                <div className="border-b-4 border-slate-800 pb-6 mb-8 text-center">
                  <h2 className="text-2xl font-serif font-bold text-slate-900 uppercase tracking-wide">National Interest Waiver Petition</h2>
                  <p className="text-slate-600 font-serif mt-2">Self-Petitioned by Ziad Nasef</p>
                </div>

                <div className="prose prose-slate max-w-none font-serif text-slate-800 whitespace-pre-wrap leading-loose">
                  
                  <h3 className="font-bold text-lg mb-4 underline">SECTION 1: INTRODUCTION</h3>
                  <div className="mb-8">{intro || <span className="text-slate-400 italic">[Introduction not provided]</span>}</div>

                  <h3 className="font-bold text-lg mb-4 underline">SECTION 2: LEGAL ARGUMENT</h3>
                  
                  <h4 className="font-bold mt-6 mb-2">I. Member of the Professions Holding an Advanced Degree</h4>
                  <div className="mb-6">{prong1 || <span className="text-slate-400 italic">[Argument not provided]</span>}</div>

                  <h4 className="font-bold mt-6 mb-2">II. Substantial Merit and National Importance</h4>
                  <div className="mb-6">{prong2 || <span className="text-slate-400 italic">[Argument not provided]</span>}</div>

                  <h4 className="font-bold mt-6 mb-2">III. Well Positioned to Advance the Endeavor</h4>
                  <div className="mb-6">{prong3 || <span className="text-slate-400 italic">[Argument not provided]</span>}</div>

                  <h4 className="font-bold mt-6 mb-2">IV. On Balance, Beneficial to Waive Job Offer</h4>
                  <div className="mb-8">{prong4 || <span className="text-slate-400 italic">[Argument not provided]</span>}</div>

                  <h3 className="font-bold text-lg mb-4 mt-12 underline" style={{ pageBreakBefore: 'always' }}>INDEX OF EXHIBITS</h3>
                  {exhibits.length === 0 ? (
                    <span className="text-slate-400 italic">[No exhibits listed]</span>
                  ) : (
                    <ul className="list-none space-y-3 pl-0">
                      {exhibits.map((exhibit, idx) => (
                        <li key={idx} className="flex gap-4">
                          <span className="font-bold whitespace-nowrap">Exhibit {idx + 1}:</span>
                          <div className="flex flex-col">
                            <span>{exhibit.title}</span>
                            {exhibit.attachedFile && (
                              <span className="text-sm text-blue-600 mt-1 flex items-center gap-1"><Paperclip /> {exhibit.attachedFile.name} (Attached)</span>
                            )}
                          </div>
                        </li>
                      ))}
                    </ul>
                  )}

                </div>
              </div>

              <div className="flex justify-center gap-4 py-8">
                <button onClick={() => setActiveStep(3)} className="px-6 py-3 rounded-xl text-slate-600 hover:bg-slate-100 transition-colors font-medium border border-slate-200 bg-white">
                  Edit Arguments
                </button>
                <button onClick={() => showToast('Exporting to DOCX format with attachments...')} className="flex items-center gap-2 bg-blue-600 text-white px-8 py-3 rounded-xl hover:bg-blue-700 transition-colors font-bold shadow-lg shadow-blue-600/20">
                  <Download /> Download Final Document
                </button>
              </div>
            </div>
          )}

        </main>
      </div>

      {/* Global Toast Notification */}
      {toastMsg && (
        <div className="fixed bottom-6 right-6 bg-slate-900 text-white px-6 py-4 rounded-xl shadow-2xl flex items-center gap-3 animate-in slide-in-from-bottom-4 z-50">
          <CheckCircle className="text-green-400" />
          <p className="font-medium text-sm">{toastMsg}</p>
        </div>
      )}
    </div>
  );
}
